# OpenLogo example 04: conditions
# level 4 uses strict booleans if else and == for equality.

clear_screen
set_color "orange"

:sides = 4
:size = 70
:is_square = :sides == 4

if :is_square [
  print "square"
  repeat :sides [
    forward :size
    right 360 / :sides
  ]
] else [
  print "not square"
  forward :size
]

:has_many_sides = :sides > 5
if not :has_many_sides [
  print "few sides"
] else [
  print "many sides"
]

# expected output: "square" then "few sides" and a square is drawn.
