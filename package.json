{
  "name": "openlogo",
  "version": "0.1.0",
  "description": "OpenLogo (OL) — a modern, open, educational reimagining of Logo. TypeScript 7 monorepo.",
  "private": true,
  "type": "module",
  "license": "MIT",
  "homepage": "https://github.com/pmalarme/open-logo",
  "repository": {
    "type": "git",
    "url": "https://github.com/pmalarme/open-logo.git"
  },
  "workspaces": [
    "packages/*"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc -b tsconfig.json",
    "typecheck": "tsc -p tsconfig.typecheck.json",
    "lint": "biome lint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "node scripts/test.mjs",
    "conformance": "node scripts/conformance.mjs",
    "examples": "node scripts/examples.mjs",
    "clean": "tsc -b tsconfig.json --clean"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.3",
    "prettier": "^3.9.5",
    "typescript": "^7.0.2"
  }
}
