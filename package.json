{
  "name": "openlogo",
  "version": "0.1.0",
  "private": true,
  "description": "OpenLogo — a modern, open, educational reimagining of Logo (TypeScript 7 monorepo).",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -b",
    "lint": "biome lint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "pretest": "npm run -s build",
    "test": "node --test",
    "precoverage": "npm run -s build",
    "coverage": "node --test --experimental-test-coverage --test-coverage-lines=100 --test-coverage-branches=100 --test-coverage-functions=100",
    "preconformance": "npm run -s build",
    "conformance": "node scripts/conformance.mjs",
    "examples": "node scripts/check-examples.mjs",
    "clean": "tsc -b --clean"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.3",
    "prettier": "^3.4.2",
    "typescript": "^7.0.2"
  }
}
