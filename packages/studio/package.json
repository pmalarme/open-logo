    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc -b",
    "clean": "tsc -b --clean"
  },
  "dependencies": {
    "@openlogo/core": "0.1.0",
    "@openlogo/parser": "0.1.0",
    "@openlogo/runtime": "0.1.0",
