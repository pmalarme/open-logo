{
  "name": "@openlogo/studio",
  "version": "0.1.0",
  "description": "OpenLogo studio: the browser learner IDE — editor/REPL, Canvas turtle view, run/stop/step, diagnostics UI, tooling, and lessons.",
  "type": "module",
